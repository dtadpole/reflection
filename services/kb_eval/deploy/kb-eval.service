[Unit]
Description=kbEval GPU kernel evaluation server
After=network.target

[Service]
Type=simple
WorkingDirectory=%h/.reflection/services/kb_eval
ExecStart=%h/.reflection/services/kb_eval/.venv/bin/python -m services.kb_eval --host 0.0.0.0 --port ${KB_EVAL_PORT} --devices ${KB_EVAL_DEVICES} --data-root %h/.reflection
Restart=always
RestartSec=5
Environment=KB_EVAL_PORT=8456
Environment=KB_EVAL_DEVICES=cuda:0

[Install]
WantedBy=default.target
