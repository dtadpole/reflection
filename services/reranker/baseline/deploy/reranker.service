[Unit]
Description=Reranker FastAPI server (cross-encoder via vLLM)
After=network.target reranker-vllm.service

[Service]
Type=simple
WorkingDirectory=%h/.reflection/services/reranker
ExecStart=%h/.reflection/services/reranker/.venv/bin/python -m services.reranker.baseline --host 0.0.0.0 --port 42983
Restart=always
RestartSec=5

[Install]
WantedBy=default.target
